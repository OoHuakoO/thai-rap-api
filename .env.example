# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string (use Transaction Pooler for serverless, Session for long-running)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for Prisma migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Minimum 32 characters — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_characters
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# TTL in milliseconds (default: 60000 = 1 minute)
THROTTLE_TTL=60000
# Max requests per TTL window
THROTTLE_LIMIT=100
