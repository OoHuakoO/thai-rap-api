generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ASSESSOR
  MENTOR
  ENTREPRENEUR
  JUDGE
  ME_TEAM
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum StoreStatus {
  REGISTERED
  T0_COMPLETED
  CAMP_COMPLETED
  T1_COMPLETED
  PITCHING_COMPLETED
  SELECTED
  CONDITIONAL_SELECTED
  WAITING_LIST
  NOT_SELECTED
  FIELD_AUDITED
  IDP_CREATED
  COMPLETED
}

enum Round {
  T0
  T1
  T2
  T3
  T4
}

enum AssessmentStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum ScoreStatus {
  PENDING
  SCORED
  FLAGGED
}

enum RedFlagType {
  FOOD_SAFETY
  FINANCIAL
  OPERATION
  MARKET
  LEGAL
  OWNER_READINESS
  EVIDENCE
  GROWTH
}

enum Severity {
  WARNING
  CRITICAL
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      Role
  status    UserStatus @default(PENDING)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  refreshToken   RefreshToken?
  assessments    Assessment[]
  assignedStores Store[]       @relation("AssignedAssessor")
  ownedStores    Store[]       @relation("StoreOwner")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Store ────────────────────────────────────────────────────────────────────

model Store {
  id               String      @id @default(cuid())
  name             String
  province         String
  storeType        String
  ownerName        String
  phone            String
  email            String?
  address          String      @db.Text
  socialLinks      Json        @default("{}")
  avgRevenueMin    Float?
  avgRevenueMax    Float?
  mainProblems     Json        @default("[]")
  goals            Json        @default("[]")
  menuPhotos       Json        @default("[]")
  coverUrl         String?
  storePhotos      Json        @default("[]")
  status           StoreStatus @default(REGISTERED)
  ownerId          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  owner         User?           @relation("StoreOwner", fields: [ownerId], references: [id])
  assessments   Assessment[]
  documents     StoreDocument[]
  assignedUsers User[]          @relation("AssignedAssessor")
}

model StoreDocument {
  id         String   @id @default(cuid())
  storeId    String
  filename   String
  fileType   String
  fileSize   Int
  url        String
  uploadedAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])
}

// ─── Lookup ───────────────────────────────────────────────────────────────────

model Province {
  id     Int    @id @default(autoincrement())
  nameTh String @unique
}

// ─── Assessment ───────────────────────────────────────────────────────────────

model Dimension {
  id            Int        @id
  name          String
  nameEn        String
  weight        Int
  questionCount Int
  questions     Question[]
}

model Question {
  id           Int       @id
  dimensionId  Int
  questionNo   Int
  questionText String    @db.Text
  maxScore     Int       @default(4)
  dimension    Dimension @relation(fields: [dimensionId], references: [id])
  scores       Score[]
}

model Assessment {
  id          String           @id @default(cuid())
  storeId     String
  round       Round
  assessorId  String
  status      AssessmentStatus @default(DRAFT)
  totalScore  Float?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submittedAt DateTime?

  store    Store     @relation(fields: [storeId], references: [id])
  assessor User      @relation(fields: [assessorId], references: [id])
  scores   Score[]
  redFlags RedFlag[]

  @@unique([storeId, round])
}

model Score {
  id           String      @id @default(cuid())
  assessmentId String
  questionId   Int
  rawScore     Int?
  displayScore Int?
  note         String?     @db.Text
  suggestion   String?     @db.Text
  status       ScoreStatus @default(PENDING)

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  question   Question   @relation(fields: [questionId], references: [id])
  evidences  Evidence[]

  @@unique([assessmentId, questionId])
}

model Evidence {
  id         String   @id @default(cuid())
  scoreId    String
  filename   String
  fileType   String
  fileSize   Int
  url        String
  uploadedAt DateTime @default(now())

  score Score @relation(fields: [scoreId], references: [id])
}

model RedFlag {
  id               String      @id @default(cuid())
  assessmentId     String
  type             RedFlagType
  severity         Severity
  triggerQuestions Json        @default("[]")
  recommendation   String?     @db.Text
  resolved         Boolean     @default(false)

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}
